# Your league's numeric ID (from the URL on fantasy.espn.com).
LEAGUE_ID=

# Cookies copied from a logged-in browser session at fantasy.espn.com.
# Only required for private leagues. Leave blank for public ones.
# These cookies grant read access to your league — do not commit them.
ESPN_S2=
SWID=

# Optional: path to the SQLite cache file. Defaults to ./espn_cache.sqlite
# CACHE_PATH=espn_cache.sqlite
