# Postgres connection string. Default points at the docker-compose db service.
# In production this is your Neon connection string (use the "pooled" one).
DATABASE_URL=postgresql+psycopg://fantasy:dev@localhost:5432/fantasy

# Random secret used to sign session cookies. Rotate to invalidate all sessions.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Fernet symmetric encryption key for ESPN credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Comma-separated CORS origins for credentialed requests.
# Dev default is just Vite. In production with Vercel rewrites the
# browser still sees the Vercel origin, so add it here too:
# e.g. ALLOWED_ORIGINS=https://espn-fantasy-stats.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# Cookie hardening — leave as defaults for local dev.
# In production behind HTTPS: COOKIE_SECURE=true
# If frontend and backend are on different origins (no proxy): COOKIE_SAME_SITE=none
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# OPTIONAL: used by the admin seed command to bootstrap the first user/league
# from a single ESPN league's credentials. Safe to leave blank in production.
LEAGUE_ID=
ESPN_S2=
SWID=
